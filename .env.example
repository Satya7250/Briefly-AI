# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/superhuman_clone"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret-key-in-production"

# Google OAuth (from: https://console.cloud.google.com/)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# OpenAI (from: https://platform.openai.com/api-keys)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Corsair (from: https://corsair.dev/)
CORSAIR_API_KEY="your-corsair-api-key"
CORSAIR_API_URL="https://api.corsair.dev"

# Application
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3000"
SESSION_COOKIE_NAME="briefing:session"
